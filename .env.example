# Sentinel AI Suite - Environment Variables Template
# Never commit .env.local to version control
# ==========================================

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Neon PostgreSQL Database URL
# Format: postgresql://[user]:[password]@[host]/[database]?sslmode=require
# Get this from: https://console.neon.tech
VITE_NEON_DATABASE_URL=

# =============================================================================
# AI MODEL PROVIDERS
# =============================================================================

# Google Gemini API Key
# Get this from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# GitHub Copilot Token (for advanced features)
# Get this from: GitHub Settings > Developer settings > Personal access tokens
VITE_GITHUB_COPILOT_TOKEN=

# =============================================================================
# SPARK RUNTIME CONFIGURATION
# =============================================================================

# Spark App ID (auto-generated, do not modify unless deploying to production)
VITE_SPARK_APP_ID=6ae71f4d37a1f80fc3a3

# Enable debug logging for Spark runtime
VITE_SPARK_DEBUG=false

# =============================================================================
# APPLICATION FEATURES
# =============================================================================

VITE_ENABLE_NGO_MODULE=true
# Enable plagiarism checker

VITE_ENABLE_HUMANIZER=true
# =========================

# Secret encryption salt (a


# ===================
# ========================


VITE_PRO_PLAN_BUDGET_CE
# Team plan monthly budget in cents (default: $50.00)

# DEVELOPMENT & DEBUGGING


# Enable performance monitoring


# =============================================================================
# ======================
# Default brand theme (sentinel_modern | techpigeon_classic)

VITE_ALLOW_THEME_SWITCHING=true
